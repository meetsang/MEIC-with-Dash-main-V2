# Broker: schwab | tastytrade
BROKER=tastytrade

# Schwab (existing)
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_ACCT=

# TastyTrade OAuth2 (register at my.tastytrade.com > API)
TT_CLIENT_SECRET=
TT_REFRESH_TOKEN=
TT_ACCOUNT_NUMBER=
TT_IS_TEST=false

# Paper trading via tastyware.dev ($30/mo, first month free)
PAPER_MODE=false
TASTYWARE_API_KEY=

# Trade state directories (relative to project root) — V2 unified layout
TRADES_ACTIVE_DIR=trades/active/MEIC_IC
TRADES_CLOSED_DIR=trades/history/MEIC_IC
MANUAL_SPREAD_ACTIVE_DIR=trades/active/MANUAL_SPREAD
MANUAL_SPREAD_CLOSED_DIR=trades/history/MANUAL_SPREAD

# Software breach readiness (Phase 4)
BREACH_FILL_GRACE_SEC=10
MAX_MQTT_BREACH_QUOTE_AGE_SEC=5
MAX_MQTT_PAIR_SKEW_SEC=2
MQTT_SPREAD_WIDTH_TOLERANCE=0.05
BREACH_CONFIRM_OBSERVATIONS=2
BREACH_CONFIRM_MAX_WINDOW_SEC=3

# Adaptive working-stop REST reconcile (Phase 2)
STOP_RECONCILE_OPEN_SEC=15
STOP_RECONCILE_OPEN_JITTER_SEC=5
STOP_RECONCILE_STALE_SEC=10
STOP_RECONCILE_CLOSING_SEC=5

# Phase 5 — MQTT entry fallback during REST cooldown / low coverage
ENTRY_MQTT_FALLBACK_ENABLED=true
ENTRY_REST_MIN_COVERAGE_PCT=50
ENTRY_MQTT_READY_TIMEOUT_SEC=5
MAX_MQTT_ENTRY_QUOTE_AGE_SEC=10
MAX_MQTT_ENTRY_PAIR_SKEW_SEC=2
MQTT_REQUIRE_POST_SCAN_QUOTE=true

# New-risk REST gate
REST_READY_MAX_AGE_SEC=60
REST_PROBE_MIN_INTERVAL_SEC=10
REST_PROBE_TIMEOUT_SEC=10
REST_PROBE_HARD_DEADLINE_SEC=27
REST_PROBE_ON_SESSION_START=true
REST_PROBE_BEFORE_NEW_ENTRY=true
REST_PROBE_COORDINATOR_ENABLED=true
PRE_TRANCHE_PROBE_LEAD_SEC=30
BROKER_INIT_TIMEOUT_SEC=15

# Account-wide REST governor (cross-process on Windows)
TT_REST_MAX_PER_SEC=1
TT_REST_BURST=3
TT_REST_CROSS_PROCESS=true

# Entry burst control
MEIC_ENTRY_SIDE_STAGGER_SEC=2.0
MEIC_ENTRY_SIDE_ORDER=P,C

# Gate behavior
NEW_RISK_GATE_ENABLED=true
NEW_RISK_REQUIRE_OPERATOR_RESUME=true

# Launcher
RUN_ONE_DAY_DEFAULT=false
